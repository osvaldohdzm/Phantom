# =============================================================================
# Phantom SecOps — variables de entorno (copiar a .env)
#   cp .env.example .env
# =============================================================================

# --- Base de datos (Docker Compose usa estos valores) ---
POSTGRES_USER=phantom
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=katana_security_db

# --- Seguridad (obligatorio en producción) ---
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRE_MINUTES=480
AUTH_REQUIRED=true
# VAULT_MASTER_KEY=base64_32_bytes_optional

# --- Puertos ---
PHANTOM_HTTP_PORT=3000
# PHANTOM_BACKEND_PORT=8000   # solo desarrollo nativo (./start-dev.sh)

# --- API / workers ---
UVICORN_WORKERS=2
# API_PROXY_URL=http://127.0.0.1:8000   # desarrollo nativo; en Docker: http://api:8000

# --- IA (opcional; sin clave, funciones IA usan modo local/degradado) ---
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Desarrollo nativo (mkcert / Tailscale / LAN) ---
# CERT_EXTRA_HOSTS=192.168.1.10 100.x.x.x
# DEV_ALLOWED_ORIGINS=localhost,127.0.0.1,192.168.1.10
# NEXT_PUBLIC_API_BASE_URL=https://your-host:3000

# --- Credenciales por defecto tras el primer arranque ---
# Usuario: phantom  |  Contraseña: phantom
# Cambiar: ./change.sh
