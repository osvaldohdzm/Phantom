# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env — nunca commitear secretos; sí las plantillas
.env
.env.local
.env.*.local
!.env.example
!.env.local.example
backend/.env
!backend/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# certs (generar con scripts/generate-certs.sh o en Docker)
certificates/

# herramientas locales opcionales
Phantom-Tool/

# python
backend/.venv/
**/__pycache__/
**/*.pyc
backend/.pytest_cache/

# datos de runtime (no versionar)
uploads/
backend/storage/branding/
backend/storage/reports/
# plantillas Word subidas por usuarios (mantener directorio vacío)
backend/storage/templates/*
!backend/storage/templates/.gitkeep

# scratch / tests locales
test-gen.ts
test-parser.js
test-parser.ts
